# ── Server ─────────────────────
NODE_ENV=development
PORT=5000

# ── Database ────────────────────
# MongoDB Database (Active)
DATABASE_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=susan-project

# MySQL Database (Backup - uncomment to switch)
# DATABASE_URI=mysql://user:pass@localhost:3306/db_name

# ── JWT ─────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_key
JWT_EXPIRES_IN=7d

# ── File Uploads ─────────────────
MAX_FILE_SIZE_MB=5
UPLOADS_PATH=src/uploads

# ── AI Assistant (Groq) ──────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
